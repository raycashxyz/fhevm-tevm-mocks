{
  "name": "fhevm-tevm-mocks",
  "version": "0.4.1",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "description": "Tevm-native adapter primitives for running Zama FHEVM mock tests in an in-memory EVM.",
  "keywords": [
    "ethereum",
    "evm",
    "fhevm",
    "tevm",
    "testing",
    "zama"
  ],
  "license": "MIT",
  "author": "Valerio Leo",
  "packageManager": "pnpm@10.18.3",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "viem": ">=2.37.9 <2.55.0"
  },
  "dependencies": {
    "@fhevm/host-contracts": "0.10.0",
    "@fhevm/mock-utils": "^0.4.2",
    "@fhevm/solidity": "0.11.1",
    "@zama-fhe/relayer-sdk": "0.4.4",
    "ethers": "^6.16.0",
    "tevm": "1.0.0-next.149"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.15.3",
    "prettier": "^3.9.1",
    "solc": "0.8.24",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3",
    "unrun": "^0.3.1",
    "viem": "2.44.2",
    "vitest": "^4.0.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raycashxyz/fhevm-tevm-mocks.git"
  },
  "homepage": "https://github.com/raycashxyz/fhevm-tevm-mocks#readme",
  "bugs": {
    "url": "https://github.com/raycashxyz/fhevm-tevm-mocks/issues"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "keccak"
    ]
  }
}
